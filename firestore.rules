rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidDiagram(data) {
      return data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.nodes is list &&
             data.edges is list &&
             data.ownerId is string &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             (data.displayName == null || data.displayName is string) &&
             (data.photoURL == null || data.photoURL is string);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /diagrams/{diagramId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      request.resource.data.ownerId == request.auth.uid &&
                      isValidDiagram(request.resource.data);
      allow update: if isAuthenticated() && 
                      resource.data.ownerId == request.auth.uid &&
                      isValidDiagram(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
  }
}
